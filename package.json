{
  "name": "mecorion",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @mecorion/web run dev --",
    "build": "npm --workspace @mecorion/web run build",
    "preview": "npm --workspace @mecorion/web run preview",
    "api:dev": "npm --workspace @mecorion/api run dev",
    "api:build": "npm --workspace @mecorion/api run build",
    "api:typecheck": "npm --workspace @mecorion/api run typecheck",
    "worker:dev": "npm --workspace @mecorion/media-worker run dev",
    "worker:build": "npm --workspace @mecorion/media-worker run build",
    "db:up": "docker-compose -f infrastructure/docker-compose.yml up -d postgres",
    "db:down": "docker-compose -f infrastructure/docker-compose.yml down",
    "db:migrate": "npm --workspace @mecorion/api run db:migrate",
    "db:seed": "npm --workspace @mecorion/api run db:seed",
    "typecheck": "npm --workspace @mecorion/api run typecheck && npm --workspace @mecorion/media-worker run typecheck"
  }
}
